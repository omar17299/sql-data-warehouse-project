/*  
This script creats a database called 'DataWarehouse', 
with three main schemas called 'bronze', 'silver', 'gold

------------WWWWWWWWWARNINGGGGGGGGGGGGG-----
RUNNING THESE CODE WILL DELETE THE WHOLE DATABASE AND RECREATE IT AGAIN, 
SO THESE IS ONE TIME SCRIPT USE,
IF U ALREADY USED IT AND THE DATABASE ALREADY EXISTS DO NOT RUN IT AGAIN 
*/
USE master;
GO 

-- Drop the database if exists
IF EXISTS (SELECT * FROM sys.databases WHERE name = 'DataWarehouse')
BEGIN 
	ALTER DATABASE DataWarehouse SET SINGLE_USER WITH ROLLBACK IMMEDIATE; 
	DROP DATABASE DataWarehouse;
END;
GO 

-- Creating the database
CREATE DATABASE DataWarehouse;
GO

USE DataWarehouse;
GO

--Create schemas
CREATE SCHEMA bronze;
GO

CREATE SCHEMA silver;
GO

CREATE SCHEMA gold;
GO

